# ============ LLM ============
# OpenAI compatible protocol. Default: DeepSeek (accessible from China, cheap).
# Register at https://platform.deepseek.com and create an API Key, then replace below.
# Note: deepseek-chat will be deprecated on 2026-07-24, switch to deepseek-v4-flash then.
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
LLM_MODEL=deepseek-chat

# ============ STT (Speech to Text) ============
# Options: local_whisper | volcengine_asr | openai_compat
#
# - local_whisper: local faster-whisper, free, recommended default
# - volcengine_asr: Volcengine streaming ASR 2.0, higher Chinese accuracy,
#   supports real-time subtitles. Sign up at:
#   https://console.volcengine.com/speech/service/10007
# - openai_compat: uses the OPENAI_* Whisper API endpoint
STT_PROVIDER=local_whisper
# local whisper model: tiny | base | small | medium | large-v3
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Volcengine ASR API Key (only needed when STT_PROVIDER=volcengine_asr)
VOLCENGINE_ASR_API_KEY=

# ============ TTS (Text to Speech) ============
# Options: edge | openai_compat | doubao
#
# - edge: free Microsoft Edge TTS, recommended default
# - doubao: Volcengine TTS, more natural Chinese voice (paid, ~0.05 RMB/session)
# - openai_compat: uses the OPENAI_* TTS endpoint
TTS_PROVIDER=edge
# edge-tts Chinese voices: zh-CN-XiaoxiaoNeural / zh-CN-YunjianNeural / zh-CN-YunxiNeural
TTS_VOICE=zh-CN-YunjianNeural

# Doubao TTS credentials (only needed when TTS_PROVIDER=doubao)
DOUBAO_APP_ID=
DOUBAO_ACCESS_TOKEN=
DOUBAO_CLUSTER=volcano_tts
DOUBAO_VOICE_TYPE=zh_male_m191_uranus_bigtts

# ============ Database ============
# Engine: mysql (requires Docker MySQL container) | sqlite (local file, recommended for China)
# When using sqlite, the MYSQL_* fields below are ignored.
DB_ENGINE=mysql
# --- Below only needed when DB_ENGINE=mysql ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=offer
MYSQL_PASSWORD=offer_pass
MYSQL_DATABASE=offer_master
MYSQL_ROOT_PASSWORD=root_pass

# ============ Interview Policy ============
QUESTIONS_PER_ROUND_MIN=5
QUESTIONS_PER_ROUND_MAX=8
MAX_FOLLOWUPS=2
FOLLOWUP_STRATEGY=balanced
ROUND_PASS_THRESHOLD=70

# ============ Storage ============
STORAGE_DIR=/data
